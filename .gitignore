# ---- Secrets (NEVER commit) ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Python / backend ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log

# ---- Node / frontend ----
node_modules/
dist/
dist-ssr/
*.local
.vite/

# ---- Build / model caches ----
.cache/
.huggingface/
models--*/

