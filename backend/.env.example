# Copy to backend/.env for LOCAL DEV ONLY. backend/.env is gitignored.
# In deployment these come from AWS Secrets Manager (see infra/DEPLOY.md), NOT this file.

# local | production  — selects the secrets source (env vs Secrets Manager)
APP_ENV=local

# --- Local DB (matches docker-compose.yml) ---
# asyncpg driver URL. In production this is assembled from the Secrets Manager payload.
DATABASE_URL=postgresql+asyncpg://scribe:scribe_local_dev@localhost:5432/scribe

# --- Gemini ---
# Get a key at https://aistudio.google.com/apikey . Leave blank until M4 generation.
# NOTE: this file is COMMITTED — never put a real key here. Real keys go in backend/.env only.
GEMINI_API_KEY=

# --- Session cookie ---
# For local http dev set COOKIE_SECURE=false; in production it MUST be true (HTTPS).
COOKIE_SECURE=false

# --- Production-only (ignored when APP_ENV=local) ---
# Name/ARN of the Secrets Manager secret holding DB creds + Gemini key as JSON.
AWS_REGION=us-east-1
APP_SECRET_NAME=clinical-scribe/app
